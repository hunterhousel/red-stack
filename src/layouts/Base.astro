---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'RedStack — Claude Code, MCP Server & AI Implementation for Business',
  description = 'Expert Claude Code, MCP server, AI workflow implementation, ClawdBot voice AI builds, and lead generation for businesses. We set up your AI infrastructure so you can ship faster.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="Claude Code setup, MCP server implementation, AI automation, Claude API integration, agentic workflows, AI consulting, ClawdBot, voice AI, AI phone answering, lead scraping, lead generation, appointment booking AI, RedStack" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://red-stack.com/" />
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:title" content="RedStack — Claude Code, MCP & AI Implementation" />
  <meta property="og:description" content="We implement Claude Code, MCP servers, ClawdBot voice AI, API integrations, and agentic workflows inside your company. Done in days, not months." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://red-stack.com/" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="RedStack — AI Implementation" />
  <meta name="twitter:description" content="Claude Code, MCP servers, ClawdBot, and AI workflows — implemented inside your company in days." />

  <!-- Schema.org ProfessionalService -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "RedStack",
    "url": "https://red-stack.com",
    "description": "Expert implementation of Claude Code, MCP servers, Anthropic API integrations, OpenClaw personal AI assistants, CallPark AI receptionists, and agentic AI workflows for businesses.",
    "serviceType": ["AI Implementation", "Claude Code Setup", "MCP Server Configuration", "API Integration", "AI Workflow Automation", "OpenClaw Setup", "CallPark AI Receptionist", "AI Phone Answering", "Lead Generation"],
    "areaServed": "US",
    "priceRange": "$$$",
    "knowsAbout": ["Claude Code", "Model Context Protocol", "MCP Servers", "Anthropic API", "Agentic AI", "AI Automation", "Claude AI", "LLM Integration", "OpenClaw", "ClawdBot", "Personal AI Assistant", "CallPark", "AI Receptionist", "AI Phone Answering", "SMS Automation", "Appointment Booking AI", "Lead Scraping", "Lead Generation"],
    "offers": [
      { "@type": "Offer", "name": "Starter Setup", "description": "Claude Code environment setup, basic MCP server connections, team onboarding", "price": "5000", "priceCurrency": "USD" },
      { "@type": "Offer", "name": "Full Implementation", "description": "End-to-end AI infrastructure: Claude Code, MCP servers, OpenClaw, CallPark, API integrations, custom workflows, automation pipelines", "price": "15000", "priceCurrency": "USD" },
      { "@type": "Offer", "name": "Enterprise Retainer", "description": "Ongoing AI implementation support, OpenClaw and CallPark management, new workflow builds, lead generation, optimization, and team training", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "5000", "priceCurrency": "USD", "unitText": "month" } }
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "AI Implementation Services",
      "itemListElement": [
        "Claude Code Setup & Configuration",
        "MCP Server Implementation",
        "Anthropic API Integration",
        "OpenClaw Personal AI Assistant Setup",
        "CallPark AI Receptionist Deployment",
        "Agentic AI Workflow Design",
        "AI Automation Pipelines",
        "SMS & Appointment Booking Automation",
        "Lead Scraping & Data Pipelines",
        "Team Training & Onboarding"
      ]
    }
  })} />

  <!-- Schema.org FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is Claude Code and why do I need it?", "acceptedAnswer": { "@type": "Answer", "text": "Claude Code is Anthropic's command-line tool for agentic AI coding. It lets your developers delegate coding tasks to Claude directly from the terminal — editing files, running commands, searching codebases, and managing git workflows. Most teams need help configuring it properly for their specific stack, permissions, and workflows." } },
      { "@type": "Question", "name": "What are MCP servers and how do they help my business?", "acceptedAnswer": { "@type": "Answer", "text": "MCP (Model Context Protocol) servers let Claude connect to your existing tools — Slack, Google Drive, GitHub, Salesforce, databases, and more. Instead of copy-pasting context, Claude can directly read and act on your company's data. Setting up MCP servers correctly requires understanding your tool stack, authentication, and data flows." } },
      { "@type": "Question", "name": "How long does an AI implementation take?", "acceptedAnswer": { "@type": "Answer", "text": "Most implementations are completed in 1-2 weeks. A basic Claude Code + MCP setup can be done in 3-5 days. Full enterprise implementations with custom workflows, API integrations, and automation pipelines typically take 2-3 weeks." } },
      { "@type": "Question", "name": "How much does AI implementation cost?", "acceptedAnswer": { "@type": "Answer", "text": "Starter engagements begin at $5,000 for Claude Code setup and basic MCP connections. Full implementations with API integrations and custom workflows start at $15,000. Enterprise retainers for ongoing support start at $5,000/month." } },
      { "@type": "Question", "name": "What tools and platforms can you connect with MCP?", "acceptedAnswer": { "@type": "Answer", "text": "We connect Claude to virtually any tool your team uses: Slack, GitHub, Google Drive, Google Calendar, Gmail, Salesforce, Jira, Asana, Notion, PostgreSQL, MySQL, Stripe, HubSpot, Linear, Figma, and many more. If an MCP server exists for it — or needs to be built — we handle it." } },
      { "@type": "Question", "name": "Do you build custom AI automations and workflows?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Beyond setup, we design and build agentic AI workflows — automated pipelines where Claude handles multi-step business processes like lead qualification, document processing, code review, customer support triage, data analysis, and reporting." } },
      { "@type": "Question", "name": "What is ClawdBot and what can it do for my business?", "acceptedAnswer": { "@type": "Answer", "text": "OpenClaw (formerly ClawdBot) is an open-source personal AI assistant that runs on your own hardware. It connects to your messaging apps like WhatsApp, Telegram, Slack, and Discord, remembers everything, and takes real actions — managing email, calendar, smart home, browser automation, and more. We handle the full setup, channel integration, custom skills, and proactive routines." } },
      { "@type": "Question", "name": "What is CallPark?", "acceptedAnswer": { "@type": "Answer", "text": "CallPark is an AI receptionist service that answers your business phone 24/7, handles SMS conversations, books appointments, and qualifies leads. We configure it for your specific industry with custom scripts, business logic, and calendar integration." } },
      { "@type": "Question", "name": "Can you help with lead generation and data scraping?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build custom lead scraping pipelines that pull verified business data — names, phone numbers, emails, and more — from Google Maps, industry directories, and public databases. We clean, deduplicate, and deliver the data in ready-to-use formats. Available as an add-on to any service tier." } }
    ]
  })} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <slot />
</body>
</html>
