---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const postFiles = import.meta.glob('../../content/blog/*.md', { eager: true });
  const posts = Object.values(postFiles) as any[];
  return posts.map(post => ({
    params: { slug: post.frontmatter.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
---
<Base title={`${post.frontmatter.title} — RedStack`} description={post.frontmatter.excerpt}>

<nav>
  <a href="/" class="nav-logo"><span>//</span> REDSTACK</a>
  <div class="nav-links">
    <a href="/#services">Services</a>
    <a href="/#clawdbot">OpenClaw</a>
    <a href="/#callpark">CallPark</a>
    <a href="/#pricing">Pricing</a>
    <a href="/blog">Blog</a>
    <a href="/#book" class="nav-cta">Book a Call</a>
  </div>
</nav>

<article class="blog-post">
  <div class="blog-post-meta">
    <a href="/blog" class="blog-back">← Back to Blog</a>
    <span class="blog-post-tag">{post.frontmatter.tag}</span>
    <span class="blog-post-date">{post.frontmatter.date}</span>
  </div>
  <h1 class="blog-post-title">{post.frontmatter.title}</h1>
  <div class="blog-post-body">
    <Content />
  </div>

  <div class="blog-post-cta">
    <p>Need help implementing this? We set it up for you.</p>
    <a href="https://cal.com/redstackai/30min" target="_blank" rel="noopener" class="btn-primary">Book a Call ↗</a>
  </div>
</article>

<footer>
  <a href="/" class="nav-logo"><span>//</span> REDSTACK</a>
  <div class="btc-badge btc-badge-sm">
    <span class="btc-icon">₿</span>
    <span>Bitcoin Accepted</span>
  </div>
  <div><a href="https://red-stack.com">red-stack.com</a></div>
</footer>

<style>
  .blog-post {
    max-width: 720px;
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
  }

  .blog-post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .blog-back {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--light-gray);
    transition: color 0.3s;
    margin-right: auto;
  }
  .blog-back:hover { color: var(--red); }

  .blog-post-tag {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--red);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(232,27,27,0.1);
    border: 1px solid rgba(232,27,27,0.2);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
  }

  .blog-post-date {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--light-gray);
  }

  .blog-post-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--mid-gray);
  }

  .blog-post-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--cream);
  }

  .blog-post-body :global(h2) {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
    color: var(--white);
  }

  .blog-post-body :global(h3) {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    color: var(--white);
  }

  .blog-post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .blog-post-body :global(code) {
    font-family: var(--mono);
    font-size: 0.88rem;
    background: var(--dark-gray);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    color: var(--red);
  }

  .blog-post-body :global(pre) {
    background: var(--dark-gray);
    border: 1px solid var(--mid-gray);
    border-radius: 6px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .blog-post-body :global(pre code) {
    background: none;
    padding: 0;
    color: var(--cream);
  }

  .blog-post-body :global(ul), .blog-post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .blog-post-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .blog-post-body :global(strong) {
    color: var(--white);
    font-weight: 600;
  }

  .blog-post-body :global(a) {
    color: var(--red);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-post-body :global(blockquote) {
    border-left: 3px solid var(--red);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--light-gray);
    font-style: italic;
  }

  .blog-post-cta {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--dark-gray);
    border: 1px solid rgba(232,27,27,0.2);
    border-radius: 8px;
    text-align: center;
  }

  .blog-post-cta p {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--white);
  }
</style>

</Base>
