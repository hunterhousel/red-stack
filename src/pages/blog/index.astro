---
import Base from '../../layouts/Base.astro';

// Get all blog posts
const postFiles = import.meta.glob('../../content/blog/*.md', { eager: true });
const posts = Object.values(postFiles) as any[];
const sortedPosts = posts.sort((a: any, b: any) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---
<Base title="Blog — RedStack" description="Guides, tutorials, and insights on Claude Code, MCP servers, OpenClaw, AI automation, and implementation strategies for businesses.">

<nav>
  <a href="/" class="nav-logo"><span>//</span> REDSTACK</a>
  <div class="nav-links">
    <a href="/#services">Services</a>
    <a href="/#clawdbot">OpenClaw</a>
    <a href="/#callpark">CallPark</a>
    <a href="/#pricing">Pricing</a>
    <a href="/blog">Blog</a>
    <a href="/#book" class="nav-cta">Book a Call</a>
  </div>
</nav>

<section style="padding-top:8rem;max-width:800px;margin:0 auto;">
  <p class="section-label">// Blog</p>
  <h1 class="section-title">Guides, builds & insights.</h1>
  <p class="section-sub">Practical deep dives on Claude Code, MCP servers, OpenClaw, CallPark, and everything AI implementation.</p>

  <div class="blog-list">
    {sortedPosts.map((post) => (
      <a href={`/blog/${post.frontmatter.slug}`} class="blog-card">
        <div class="blog-card-meta">
          <span class="blog-card-tag">{post.frontmatter.tag}</span>
          <span class="blog-card-date">{post.frontmatter.date}</span>
        </div>
        <h2 class="blog-card-title">{post.frontmatter.title}</h2>
        <p class="blog-card-excerpt">{post.frontmatter.excerpt}</p>
        <span class="blog-card-read">Read →</span>
      </a>
    ))}
  </div>
</section>

<footer style="margin-top:4rem;">
  <a href="/" class="nav-logo"><span>//</span> REDSTACK</a>
  <div class="btc-badge btc-badge-sm">
    <span class="btc-icon">₿</span>
    <span>Bitcoin Accepted</span>
  </div>
  <div><a href="https://red-stack.com">red-stack.com</a></div>
</footer>

<style>
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .blog-card {
    display: block;
    background: var(--dark-gray);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 8px;
    padding: 2rem;
    transition: all 0.3s;
    text-decoration: none;
    color: inherit;
  }
  .blog-card:hover {
    border-color: rgba(232,27,27,0.3);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .blog-card-tag {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--red);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(232,27,27,0.1);
    border: 1px solid rgba(232,27,27,0.2);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
  }

  .blog-card-date {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--light-gray);
  }

  .blog-card-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .blog-card-excerpt {
    font-size: 0.92rem;
    color: var(--light-gray);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .blog-card-read {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--red);
    font-weight: 600;
  }
</style>

</Base>
