<!-- SCRIPTS -->
<script>
  // FAQ toggles
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('open');
      btn.nextElementSibling?.classList.toggle('open');
    });
  });

  // Flyout panel
  const trigger = document.getElementById('flyout-trigger');
  const overlay = document.getElementById('flyout-overlay');
  const panel = document.getElementById('flyout-panel');
  const closeBtn = document.getElementById('flyout-close');
  const flyoutBook = document.getElementById('flyout-book');

  function openFlyout() {
    overlay?.classList.add('open');
    panel?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeFlyout() {
    overlay?.classList.remove('open');
    panel?.classList.remove('open');
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', openFlyout);
  overlay?.addEventListener('click', closeFlyout);
  closeBtn?.addEventListener('click', closeFlyout);
  flyoutBook?.addEventListener('click', closeFlyout);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeFlyout();
  });
</script>

